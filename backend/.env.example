# LLM (at least one provider required for describe / ingest / review)
ZAI_API_KEY=
ZAI_MODEL=glm-5.2
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Neo4j Aura (optional — graph write skipped when unset)
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_CONSOLE_URL=https://console.neo4j.io

# GitHub OAuth (user login)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8000/auth/github/callback
SESSION_TTL_SECONDS=604800
OAUTH_COOKIE_SECURE=false

# GitHub App (webhook + PR comments — separate from OAuth)
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Set GitHub App "Setup URL" to: http://localhost:3000/install/complete
# Subscribe the app to Pull request events

# browser-use cloud (required for live crawl)
BROWSER_USE_API_KEY=
CRAWL_BROWSERUSE_CONCURRENCY=3
CRAWL_AGENT_MAX_COST_USD=2.0

FRONTEND_ORIGIN=http://localhost:3000
